{
    "name": "Gravimetry Processing (with offset and drift)",
    "function": "pytechsas.sensor.techsas_gravi_process.process_gravity_files",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/sensor/techsas_gravi.html",
    "pages": [
        {
            "title": "Gravity drift parameters",
            "parameters": [
                "g_zero",
                "g_zero_date",
                "drift"
            ]
        },
        {
            "title": "Gravimeter settings",
            "parameters": [
                "filter_delay",
                "install_spring_stiffness",
                "real_spring_stiffness"
            ]
        }
    ],
    "parameters": [
        {
            "name": "i_paths",
            "key": "-i_paths",
            "help": "Input file list",
            "nargs": "+",
            "type": "infile(content_type=TECHSAS_NETCDF_GRAVI)"
        },
        {
            "name": "g_zero",
            "type": "float",
            "key": "-g_zero",
            "units": "mGal",
            "help": "Gravity offset (mgal)"
        },
        {
            "name": "g_zero_date",
            "type": "datetime",
            "key": "-g_zero_date",
            "help": "Gravity offset date"
        },
        {
            "name": "drift",
            "type": "float",
            "key": "-drift",
            "help": "Drift (mgal/day)"
        },
        {
            "name": "filter_delay",
            "key": "-filter_delay",
            "type": "int",
            "help": "Filter delay in seconds"
        },
        {
            "name": "install_spring_stiffness",
            "type": "float",
            "key": "--install_spring_stiffness",
            "help": "Installation value"
        },
        {
            "name": "real_spring_stiffness",
            "type": "float",
            "key": "--real_spring_stiffness",
            "help": "Real value"
        },
        {
            "name": "o_paths",
            "key": "-o_paths",
            "help": "Output file (.nc)",
            "nargs": "+",
            "type": "outfile(content_type=TECHSAS_NETCDF_GRAVI)"
        },
        {
            "name": "overwrite",
            "key": "--overwrite",
            "help": "Allow to overwrite file if already exists.",
            "type": "outfile#overwrite"
        }
    ]
}
