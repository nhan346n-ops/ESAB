{
    "name": "Apply Navigation",
    "function": "pyat.sensor.techsas_apply_navigation.apply_navigation_batch",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/sensor/techsas_apply_navigation.html",
    "parameters": [
        {
            "name": "i_paths",
            "key": "-in",
            "long_key": "--i_paths",
            "help": "input files list (techsas)",
            "nargs": "+",
            "type": "infile(content_type=TECHSAS)"
        },
        {
            "name": "o_paths",
            "key": "-o",
            "long_key": "--o_paths",
            "help": "output files list",
            "nargs": "+",
            "type": "outfile(content_type=TECHSAS)"
        },
        {
            "name": "overwrite",
            "key": "-ow",
            "long_key": "--overwrite",
            "help": "Allow to overwrite file if already exists.",
            "type": "outfile#overwrite"
        },
        {
            "name": "i_nav_files",
            "key": "-nav",
            "long_key": "--i_nav_files",
            "nargs": "*",
            "help": "Navigation files (.nvi/.nav/.subnav/.gps)",
            "type": "file(content_type=NVI_NETCDF_4|NVI_V2_NETCDF_4,extensions=nav|subnav|gps|nc)"
        }
    ]
}
