{
    "name": "Data Filter",
    "function": "pyat.sensor.data_filter.apply_filter_batch",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/sensor/data_filter.html",
    "parameters": [
        {
            "name": "i_paths",
            "key": "-i",
            "long_key": "--i_paths",
            "nargs": "+",
            "type": "infile(content_type=TECHSAS)"
        },
        {
            "name": "o_paths",
            "key": "-o",
            "long_key": "--o_paths",
            "help": "output files list",
            "nargs": "+",
            "type": "outfile(content_type=TECHSAS,suffix=filtered)"
        },
        {
            "name": "overwrite",
            "key": "-ow",
            "long_key": "--overwrite",
            "help": "Allow overwrite file if already exists.",
            "type": "outfile#overwrite"
        },
        {
            "name": "filters",
            "type": "layer_filters",
            "help": "List of filters."
        }
    ]
}
