{
    "name": "Remove Invalid Data",
    "function": "pyat.sensor.sensor_remove_invalid_data.apply_remove_batch",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/sensor/remove_invalid_data.html",
    "parameters": [
        {
            "name": "i_paths",
            "help": "Input file list",
            "nargs": "+",
            "type": "infile(content_type=TECHSAS)"
        },
        {
            "name": "o_paths",
            "key": "-o",
            "long_key": "--o_paths",
            "help": "output files list",
            "nargs": "+",
            "type": "outfile(content_type=TECHSAS,suffix=valid_data)"
        },
        {
            "name": "overwrite",
            "key": "-ow",
            "long_key": "--overwrite",
            "help": "Allow overwrite file if already exists.",
            "type": "outfile#overwrite"
        },
        {
            "name": "keep_status_variable",
            "type": "bool",
            "help": "Keep status variable"
        }
    ]
}
