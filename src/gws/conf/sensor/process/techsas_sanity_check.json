{
    "name": "Sanity Check",
    "function": "pytechsas.sensor.techsas_sanity_check.sanity_check",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/sensor/techsas_sanity_check.html",
    "parameters": [
        {
            "name": "i_paths",
            "help": "Input file list",
            "nargs": "+",
            "type": "infile(content_type=TECHSAS)"
        },
        {
            "name": "o_path",
            "help": "Output file (.csv) : summarizes found anomalies",
            "nargs": "1",
            "type": "outfile(extension=csv)"
        },
        {
            "name": "overwrite",
            "help": "Allow overwrite output file if already exists.",
            "type": "outfile#overwrite"
        },
        {
            "name": "interruption_threshold",
            "type": "duration",
            "help": "Delay to consider an interruption (0 = disabled)",
            "default" : 30
        },
        {
            "name": "ignore_invalid_status",
            "type": "bool",
            "help": "Ignore data with invalid status",
            "default" : false
        },
        {
            "name": "anomalies_processing",
            "type": "string",
            "help": "How to deal with invalid data",
            "choices": [
                "Ignore",
                "Flag as invalid",
                "Remove data"
            ],
            "default": "Flag as invalid"
        }
    ]
}
