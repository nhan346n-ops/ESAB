{
    "name": "Cross Compare",
    "function": "pytechsas.sensor.techsas_cross_compare.cross_compare",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/sensor/techsas_cross_compare.html",
    "parameters": [
        {
            "name": "i_path",
            "help": "Input file",
            "nargs": "1",
            "type": "infile(content_type=TECHSAS|MGD77)"
        },
        {
            "name": "i_path_2",
            "help": "Second input file",
            "nargs": "1",
            "type": "file(content_type=TECHSAS|MGD77)"
        },
        {
            "name": "o_path",
            "help": "Output file (.csv) : summarizes found intersections",
            "nargs": "1",
            "type": "outfile(extension=csv)"
        },
        {
            "name": "overwrite",
            "help": "Allow overwrite output file if already exists.",
            "type": "outfile#overwrite"
        },
        {
            "name": "intersection_radius",
            "type": "float",
            "default": 0.001,
            "help": "Radius of intersection area in degrees"
        },
        {
            "name": "variable_to_compare",
            "type": "string",
            "default": "gravity",
            "help": "Variable to compare"
        }
    ]
}
