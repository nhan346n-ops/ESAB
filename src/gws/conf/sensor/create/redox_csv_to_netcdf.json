{
    "name": "Redox data (.csv) to Sensor-netCDF",
    "function": "pyat.sensor.sensor_csv_to_netcdf_converter.convert",
    "help": "app/sensor/help/redox_csv_to_netcdf.html",
    "pages": [
        {
            "title": "Sanity check",
            "description": "Sanity Check : detect annomalies (duplicates, leaps back, invalid positions...)",
            "parameters": [
                "sanity_check",
                "interruption_threshold",
                "ignore_invalid_data",
                "check_latlon_0",
                "anomalies_processing"
            ]
        },
        {
            "title": "Metadata of Sensor-netCDF",
            "description": "Complete optional metadata of output files",
            "parameters": [
                "cruise_identifier",
                "cruise_name",
                "sensor_name"
            ]
        }
    ],
    "parameters": [
        {
            "name": "i_paths",
            "key": "-in",
            "long_key": "--i_paths",
            "help": "Input files",
            "nargs": "+",
            "type": "infile(content_type=PLAIN_CSV,extensions=csv|txt|csv)"
        },
        {
            "name": "csv_description",
            "type": "csv_description",
            "help": "File description",
            "default": {
                "delimiter": ",",
                "decimal_point": ".",
                "header_line": 2,
                "first_data_line": 3,
                "columns": {
                    "0": {
                        "content_type": "TIMESTAMP",
                        "format": "s"
                    },
                    "3": {
                        "content_type": "REDOX"
                    },
                    "16": {
                        "content_type": "DEPTH",
                        "format": "POSITIVE_BELOW_SURFACE"
                    },
                    "17": {
                        "content_type": "HEADING"
                    },
                    "18": {
                        "content_type": "LATITUDE",
                        "format": "DEGREES"
                    },
                    "19": {
                        "content_type": "LONGITUDE",
                        "format": "DEGREES"
                    },
                    "25": {
                        "content_type": "SPEED"
                    }
                }
            }
        },
        {
            "name": "sanity_check",
            "type": "bool",
            "help": "Detect annomalies",
            "default": false
        },
        {
            "name": "interruption_threshold",
            "type": "duration",
            "help": "Delay to consider an interruption (0 = disabled)",
            "default" : 30
        },
        {
            "name": "ignore_invalid_data",
            "type": "bool",
            "help": "Ignore invalid data",
            "default": false
        },
        {
            "name": "anomalies_processing",
            "help": "How to deal with invalid data",
            "type": "string",
            "choices": [
                "Ignore",
                "Flag as invalid",
                "Remove data"
            ],
            "default": "Flag as invalid"
        },
        {
            "name": "check_latlon_0",
            "type": "bool",
            "help": "Consider latitude/longitude equal to 0 as annomalies",
            "default": false
        },
        {
            "name": "cruise_identifier",
            "type": "string",
            "key": "-ci",
            "long_key": "--cruise_identifier",
            "help": "Cruise identifier",
            "default": ""
        },
        {
            "name": "cruise_name",
            "type": "string",
            "key": "-cn",
            "long_key": "--cruise_name",
            "help": "Cruise name",
            "default": ""
        },
        {
            "name": "sensor_name",
            "type": "string",
            "key": "-sn",
            "long_key": "--sensor_name",
            "help": "Sensor name",
            "default": ""
        },
        {
            "name": "o_paths",
            "key": "-o",
            "long_key": "--o_paths",
            "help": "output files list",
            "nargs": "+",
            "type": "outfile(extension=nc)"
        },
        {
            "name": "overwrite",
            "key": "-ow",
            "long_key": "--overwrite",
            "help": "Allow overwrite file if already exists.",
            "type": "outfile#overwrite"
        }
    ]
}
