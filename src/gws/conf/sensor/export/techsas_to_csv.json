{
    "name": "TECHSAS files to CSV (batch)",
    "function": "pyat.sensor.techsas_csv_exporter_app.TechsasCSVExporterLauncher",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/sensor/techsas_to_csv.html",
    "parameters": [
        {
            "name": "i_paths_dir",
            "key": "-ipd",
            "long_key": "--i_paths_dir",
            "nargs": "1",
            "help": "Input techsas root directory (ex: DONNEES)",
            "type": "infolder"
        },
        {
            "name": "sensors",
            "key": "-s",
            "long_key": "--sensors",
            "nargs": "+",
            "help": "Select sensors to convert",
            "type": "sensors"
        },
        {
            "name": "navigation_sensor",
            "key": "-ns",
            "long_key": "--navigation_sensor",
            "nargs": "1",
            "help": "Select navigation sensor to use for geolocation.\nAlternatively, a nvi file can be defined on next page.",
            "type": "sensors(filters=shipnav;position)"
        },
        {
            "name": "sampling",
            "key": "-ss",
            "long_key": "--sampling_step",
            "help": "Sampling step (seconds). Set to 0 to disable.",
            "default": "0",
            "type": "duration"
        },
        {
            "name": "enable_time_interval",
            "key": "-ti",
            "long_key": "--enable_time_interval",
            "help": "Use time interval",
            "default": "false",
            "type": "bool"
        },
        {
            "name": "start_date",
            "key": "-sd",
            "long_key": "--start_date",
            "help": "\tStart date (UTC)",
            "type": "datetime"
        },
        {
            "name": "end_date",
            "key": "-ed",
            "long_key": "--end_date",
            "help": "\tEnd date (UTC)",
            "type": "datetime"
        },
        {
            "name": "navigation_file",
            "key": "-nav",
            "long_key": "--navigation_file",
            "help": "Optional Nvi reference file (.nvi)",
            "nargs": "?",
            "type": "file(content_type=NVI_NETCDF_4|NVI_V2_NETCDF_4)"
        },
        {
            "name": "o_paths_dir",
            "key": "-opd",
            "long_key": "--o_paths_dir",
            "nargs": "1",
            "help": "Output directory",
            "type": "folder"
        }
    ]
}
