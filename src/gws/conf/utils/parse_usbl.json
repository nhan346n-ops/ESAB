{
    "name": "USBL log to CSV",
    "function": "pyat.sensor.parse_usbl.UsblParser",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/sensor/parse_usbl.html",
    "parameters": [
        {
            "name": "i_paths",
            "key": "-i",
            "long_key": "--i_paths",
            "help": "Input USBL file list",
            "nargs": "+",
            "type": "infile(extensions=log|txt)"
        },
        {
            "name": "o_paths",
            "key": "-o",
            "long_key": "--o_paths",
            "help": "Output file list (.csv)",
            "nargs": "+",
            "type": "outfile(extensions=csv)"
        },
        {
            "name": "overwrite",
            "key": "-ow",
            "long_key": "--overwrite",
            "help": "Allow to overwrite file if already exists.",
            "type": "outfile#overwrite"
        }
    ]
}
