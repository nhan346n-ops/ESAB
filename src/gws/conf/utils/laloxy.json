{
    "name": "Laloxy",
    "function": "pyat.csv.laloxy.Laloxy",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/utils/laloxy.html",
    "parameters": [
        {
            "name": "i_path",
            "key": "-i",
            "nargs": "1",
            "long_key": "--i-path",
            "help": "Input CSV file",
            "type": "infile(content_type=BATHIMETRIC_CSV|EMO_CSV,extensions=csv|asc|emo|txt)"
        },
        {
            "name": "o_path",
            "key": "-o",
            "long_key": "--o-path",
            "help": "Output CSV file",
            "type": "outfile(suffix=out)"
        },
        {
            "name": "mandatory_headers",
            "type": "csv#mandatory_headers",
            "nargs": "+",
            "default": [
                "Latitude/Y",
                "Longitude/X"
            ]
        },
        {
            "name": "skip_rows",
            "type": "csv#skiprows",
            "key": "-sk",
            "long_key": "--skiprows",
            "help": "Number of lines to skip at the start of the file",
            "default": 0
        },
        {
            "name": "indexes",
            "type": "csv#indexes",
            "nargs": "+",
            "key": "-idx",
            "long_key": "--indexes",
            "help": "indexes in the CSV file of each column header",
            "default": {
                "Longitude/X": "0",
                "Latitude/Y": "1"
            }
        },
        {
            "name": "delimiter",
            "type": "csv#delimiter",
            "key": "-d",
            "long_key": "--delimiter",
            "help": "Column delimiter",
            "default": ";"
        },
        {
            "name": "input_proj",
            "type": "projection",
            "default": "+proj=longlat +ellps=WGS84 +datum=WGS84 +no_defs",
            "key": "-ip",
            "long_key": "--input-proj",
            "help": "The projection to use for input coordinates"
        },
        {
            "name": "output_proj",
            "type": "projection",
            "default": "+proj=longlat +ellps=WGS84 +datum=WGS84 +no_defs",
            "key": "-op",
            "long_key": "--output-proj",
            "help": "The projection to use for output coordinates"
        },
        {
            "name": "input_format",
            "type": "string",
            "choices": [
                "XY",
                "DEGREES",
                "DEG_MIN_DEC",
                "DEG_MIN_SEC",
                "CARAIBES_XY",
                "CARAIBES_DEGREES"
            ],
            "default": "DEGREES",
            "key": "-if",
            "long_key": "--input-format",
            "help": "Input format for coordinates. "
        },
        {
            "name": "output_format",
            "type": "string",
            "choices": [
                "DEGREES",
                "DEG_MIN_DEC",
                "DEG_MIN_SEC",
                "RICHDEG_MIN_SEC",
                "XY",
                "CARAIBES_DEGREES",
                "CARAIBES_DEG_MIN_DEC",
                "CARAIBES_XY"
            ],
            "default": "RICHDEG_MIN_SEC",
            "key": "-of",
            "long_key": "--output-format",
            "help": "Output format for coordinates."
        },
        {
            "name": "rounding",
            "type": "int",
            "default": 7,
            "key": "-r",
            "long_key": "--rounding",
            "help": "Max number of digits in the decimal part in the output data."
        },
        {
            "name": "overwrite",
            "key": "-ow",
            "long_key": "--overwrite",
            "help": "Allow to overwrite file if already exists.",
            "type": "outfile#overwrite"
        }
    ]
}
