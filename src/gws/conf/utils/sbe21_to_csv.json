{
    "name": "SBE21 NMEA to CSV",
    "function": "pyat.sensor.sbe21_to_csv.CSVExporter",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/sensor/sbe21_to_csv.html",
    "parameters": [
        {
            "name": "i_paths",
            "key": "-i",
            "long_key": "--i_paths",
            "nargs": "+",
            "help": "input file list",
            "type": "infile(content_type=UNDEFINED)"
        },
        {
            "name": "navigation_file",
            "key": "-nav",
            "long_key": "--navigation",
            "help": "Nvi reference file (.nvi)",
            "nargs": "1",
            "type": "file(content_type=NVI_NETCDF_4|NVI_V2_NETCDF_4)"
        },
        {
            "name": "o_paths",
            "key": "-o",
            "long_key": "--o_paths",
            "nargs": "+",
            "help": "Output file list (.csv)",
            "type": "outfile(extension=csv,suffix=geoloc)"
        },
        {
            "name": "overwrite",
            "key": "-ow",
            "long_key": "--overwrite",
            "help": "Allow to overwrite file if already exists.",
            "type": "outfile#overwrite"
        }
    ]
}
