{
    "name": "FES2014 Harmonic Tide Predictor",
    "function": "pyat.tide.tide_app.FESTide",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/tide/fes_harmonic_tide.html",
    "parameters": [
        {
            "name": "model_dir",
            "key": "m",
            "long_key": "--model_dir",
            "nargs": "1",
            "help": "FES model input directory file",
            "type": "folder"
        },
        {
            "name": "data_file",
            "key": "-d",
            "long_key": "--data_file",
            "help": "Input data file file (.csv)",
            "nargs": "1",
            "type": "infile(content_type=UNDEFINED)"
        },
        {
            "name": "output_file",
            "key": "-o",
            "long_key": "--output_file",
            "nargs": "1",
            "help": "Output file (.csv)",
            "default": "tide_prediction.csv",
            "type": "outfile(content_type=TIDE_CSV)"
        }
    ]
}
