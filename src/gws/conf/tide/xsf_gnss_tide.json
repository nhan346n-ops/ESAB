{
    "name": "XSF GNSS tide estimator",
    "function": "pyat.tide.sensor_tide_app.XsfTide",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/tide/xsf_gnss_tide.html",
    "parameters": [
        {
            "name": "model_dir",
            "key": "m",
            "long_key": "--model_dir",
            "nargs": "?",
            "help": "tide models input directory file (containing /reference_surfaces/LAT_MSL_World_model_2003_2020.nc,\n /BATHYELLI_ZH_ell_V1_1/* and /fes2014/* folders)",
            "type": "folder"
        },
        {
            "name": "tide_server",
            "long_key": "--tide_server",
            "nargs": "?",
            "help": "Optional tide server url",
            "type": "string"
        },
        {
            "name": "input_files",
            "key": "-i",
            "long_key": "--input_files",
            "nargs": "*",
            "help": "Netcdf file (.xsf.nc)",
            "type": "infile(content_type=XSF_NETCDF_4)"
        },
        {
            "name": "output_file",
            "key": "-o",
            "long_key": "--output_file",
            "nargs": "1",
            "help": "Output file (.csv)",
            "default": "gnss_export_tide.csv",
            "type": "outfile(extension=csv)"
        },
        {
            "name": "start_date",
            "type": "datetime",
            "key": "-start_date",
            "help": "Start date"
        },
        {
            "name": "end_date",
            "type": "datetime",
            "key": "-end_date",
            "help": "End date"
        },
        {
            "name": "interval_minutes",
            "type": "int",
            "key": "-interval_minutes",
            "help": "Sampling interval (minutes)",
            "default": 1
        },
        {
            "name": "vertical_reference",
            "key": "-ref",
            "long_key": "--vertical_reference",
            "nargs": "1",
            "help": "Vertical reference : LAT(CNES), ZeroHydro/BathyElli(SHOM) or WGS84 ellipsoid",
            "type": "string",
            "choices": [
                "LAT",
                "ZH",
                "WGS84"
            ],
            "default": "LAT"
        },
        {
            "name": "altitude_reference",
            "key": "-zref",
            "long_key": "--altitude_reference",
            "nargs": "1",
            "help": "Altitude reference: optional altitude of the zero in WGS84 ellipsoid coordinates",
            "type": "float",
            "default": 0.0
        },
        {
            "name": "predictive_mode",
            "key": "-hm",
            "long_key": "--predictive_mode",
            "nargs": "1",
            "help": "Predictive mode : tide estimation based on surge relative to FES prediction",
            "type": "bool",
            "default": true
        },
        {
            "name": "positioning_type_filter",
            "key": "-tf",
            "long_key": "--positioning_type_filter",
            "nargs": "1",
            "help": "positioning type 'mode' filter (keep only RTK data)",
            "type": "bool",
            "default": true
        },
        {
            "name": "water_level",
            "key": "-wl",
            "long_key": "--water_level",
            "nargs": "?",
            "help": "Nominal waterline in platform coordinate system\n (if not defined, extracted from the XSF file)",
            "type": "double"
        },
        {
            "name": "display",
            "key": "-d",
            "long_key": "--display",
            "nargs": "1",
            "help": "display matplotlib",
            "type": "bool",
            "default": false
        }
    ]
}