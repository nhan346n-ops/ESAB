{
    "name": "FES harmonic tide predictor on navigation",
    "function": "pyat.tide.tide_app.FESTidePredictorForNavigationFiles",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/tide/navigation_harmonic_tide.html",
    "pages": [
        {
            "title": "Choose local tide model folder or server",
            "parameters": [
                "model_dir",
                "tide_server"
            ]
        }
    ],
    "parameters": [
        {
            "name": "input_files",
            "key": "-i",
            "long_key": "--input_files",
            "nargs": "*",
            "help": "Any files with navigation data (.xsf.nc/.nvi.nc/.gps...)",
            "type": "infile(content_type=XSF_NETCDF_4|NVI_NETCDF_4|NVI_V2_NETCDF_4|MBG_NETCDF_3, extensions=nc|nvi|gps|mbg|nav|subnav)"
        },
        {
            "name": "output_files",
            "key": "-o",
            "long_key": "--output_files",
            "nargs": "+",
            "help": "Output file (.ttb, .tide.nc)",
            "type": "outfile(extensions=ttb|tide.nc)"
        },
        {
            "name": "overwrite",
            "key": "-ow",
            "long_key": "--overwrite",
            "help": "Allow to overwrite file if already exists.",
            "type": "outfile#overwrite"
        },
        {
            "name": "model_dir",
            "help": "tide models input directory file (containing /reference_surfaces/LAT_MSL_World_model_2003_2020.nc,\n /BATHYELLI_ZH_ell_V1_1/* and /fes2014/* folders)",
            "nargs": "?",
            "type": "folder"
        },
        {
            "name": "tide_server",
            "help": "Tide server URL",
            "nargs": "?",
            "type": "string",
            "default": "http://telescience:80/tide"
        }
    ]
}