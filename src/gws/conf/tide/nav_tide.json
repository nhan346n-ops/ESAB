{
    "name": "Navigation Tide Estimator",
    "function": "pyat.tide.sensor_tide_app.NavTide",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/tide/nav_tide.html",
    "parameters": [
        {
            "name": "model_dir",
            "key": "m",
            "long_key": "--model_dir",
            "nargs": "?",
            "help": "tide models input directory file (containing /reference_surfaces/LAT_MSL_World_model_2003_2020.nc,\n /BATHYELLI_ZH_ell_V1_1/* and /fes2014/* folders)",
            "type": "folder"
        },
        {
            "name": "input_files",
            "key": "-i",
            "long_key": "--input_files",
            "nargs": "*",
            "help": "Navigation file (.nvi.nc/.nvi/.nav/.gps)",
            "type": "infile(content_type=NVI_NETCDF_4|NVI_V2_NETCDF_4,extensions=nav|gps)"
        },
        {
            "name": "output_file",
            "key": "-o",
            "long_key": "--output_file",
            "nargs": "1",
            "help": "Output file (.csv)",
            "default": "nav_export_tide.csv",
            "type": "outfile(extension=csv)"
        },
        {
            "name": "reference_surface",
            "key": "-ref",
            "long_key": "--reference_surface",
            "nargs": "1",
            "help": "Reference surface : LAT/MSL(CNES), ZeroHydro/BathyElli(SHOM) or WGS84 ellipsoid",
            "type": "string",
            "choices": [
                "LAT",
                "ZH",
                "ellipsoid"
            ],
            "default": "LAT"
        },
        {
            "name": "reference_altitude",
            "key": "-zref",
            "long_key": "--reference_altitude",
            "nargs": "1",
            "help": "Reference altitude : optional altitude of the zero in WGS84 ellipsoid coordinates",
            "type": "float",
            "default": 0.0
        },
        {
            "name": "predictive_mode",
            "key": "-hm",
            "long_key": "--predictive_mode",
            "nargs": "1",
            "help": "Predictive mode : tide estimation based on surge relative to FES prediction",
            "type": "bool",
            "default": true
        },
        {
            "name": "positioning_type_filter",
            "key": "-tf",
            "long_key": "--positioning_type_filter",
            "nargs": "1",
            "help": "positioning type 'mode' filter (keep only RTK data)",
            "type": "bool",
            "default": true
        },
        {
            "name": "display",
            "key": "-d",
            "long_key": "--display",
            "nargs": "1",
            "help": "display matplotlib",
            "type": "bool",
            "default": false
        }
    ]
}