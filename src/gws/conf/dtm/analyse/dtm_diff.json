{
    "name": "Difference between 2 DTM",
    "function": "pyat.dtm.analyse.dtm_diff.DiffMnt",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/dtm/analyse/dtm_diff.html",
    "parameters": [
        {
            "name": "reference_file",
            "key": "-r",
            "long_key": "--ref",
            "nargs": "1",
            "help": "Reference file (.nc)",
            "type": "file(content_type=DTM_NETCDF_4)"
        },
        {
            "name": "second_file",
            "key": "-s",
            "long_key": "--second",
            "help": "Second file (.nc)",
            "nargs": "1",
            "type": "file(content_type=DTM_NETCDF_4)"
        },
        {
            "name": "output_dir",
            "key": "-o",
            "long_key": "--output_dir",
            "nargs": "1",
            "help": "Output directory",
            "type": "folder"
        },
        {
            "name": "mask",
            "key": "-m",
            "long_key": "--mask",
            "help": "Mask file list (*.kml or *.shp)",
            "nargs": "+",
            "type": "file(content_type=KML_XML|SHAPEFILE)"
        }
    ]
}
