{
    "name": "Sanity Check",
    "function": "pyat.dtm.analyse.sanity_check_process.SanityCheckProcess",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/dtm/analyse/sanity_check.html",
    "parameters": [
        {
            "name": "i_paths",
            "key": "-i",
            "long_key": "--i_paths",
            "nargs": "+",
            "help": "Input file list (.nc)",
            "type": "infile(content_type=DTM_NETCDF_4)"
        },
        {
            "name": "o_paths",
            "key": "-o",
            "long_key": "--o_paths",
            "nargs": "+",
            "help": "Output file list (.nc)",
            "type": "outfile(content_type=DTM_NETCDF_4,suffix=sanity_check)"
        },
        {
            "name": "interp",
            "key": "-in",
            "long_key": "--interp",
            "help": "Recompute interpolation flag",
            "type": "bool"
        },
        {
            "name": "cdi",
            "key": "-c",
            "long_key": "--cdi",
            "help": "Compress cdi reference list and remove empty elements",
            "type": "bool"
        },
        {
            "name": "cdi_interp",
            "key": "-ci",
            "long_key": "--cdi_interp",
            "help": "Recompute CDI of interpolated cells (nearest valid CDI)",
            "type": "bool"
        },
        {
            "name": "reset_missing_elev",
            "key": "-rm",
            "long_key": "--reset",
            "help": "Reset cells where elevation is missing",
            "type": "bool"
        },
        {
            "name": "overwrite",
            "key": "-ow",
            "long_key": "--overwrite",
            "help": "Allow to overwrite file if already exists.",
            "type": "outfile#overwrite"
        }
    ]
}
