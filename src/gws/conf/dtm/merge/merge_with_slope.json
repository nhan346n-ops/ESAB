{
    "name": "Merge with Slope",
    "function": "pyat.dtm.merge.merge_with_slope.SlopeMerge",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/dtm/merge/merge_with_slope.html",
    "parameters": [
        {
            "name": "i_paths",
            "key": "-i",
            "long_key": "--i_paths",
            "nargs": "1",
            "help": "Reference file (.nc)",
            "type": "infile(content_type=DTM_NETCDF_4)"
        },
        {
            "name": "second_file",
            "key": "-s",
            "long_key": "--second",
            "help": "Second file (.nc)",
            "nargs": "1",
            "type": "infile(content_type=DTM_NETCDF_4)"
        },
        {
            "name": "o_path",
            "key": "-o",
            "long_key": "--o_path",
            "help": "Output file (.nc)",
            "default": "slope_merge.dtm.nc",
            "type": "outfile(content_type=DTM_NETCDF_4)"
        },
        {
            "name": "coord",
            "key": "-c",
            "long_key": "--coord",
            "help": "Coordinates of geographic bounds",
            "type": "geobox#coords"
        },
        {
            "name": "mask",
            "key": "-m",
            "long_key": "--mask",
            "help": "Mask file list (*.kml or *.shp)",
            "nargs": "+",
            "type": "file(content_type=KML_XML|SHAPEFILE)"
        },
        {
            "name": "max_slope",
            "key": "-max",
            "long_key": "--max_slope",
            "help": "max slope value (in degree)",
            "nargs": "1",
            "default": "5.5",
            "type": "float"
        },
        {
            "name": "min_slope",
            "key": "-min",
            "long_key": "--min_slope",
            "help": "min slope value (in degree)",
            "nargs": "1",
            "default": "1.0",
            "type": "float"
        },
        {
            "name": "allow_undefined_cdi",
            "key": "-u_cdi",
            "long_key": "--allow_undefined_cdi",
            "help": "Allow valid cells without CDI",
            "type": "bool"
        },
        {
            "name": "overwrite",
            "key": "-ow",
            "long_key": "--overwrite",
            "help": "Allow to overwrite file if already exists.",
            "type": "outfile#overwrite"
        }
    ]
}
