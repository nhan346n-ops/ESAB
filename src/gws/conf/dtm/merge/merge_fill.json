{
    "name": "Merge Fill",
    "function": "pyat.dtm.merge.merge_fill.MergeFillProcess",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/dtm/merge/merge_fill.html",
    "parameters": [
        {
            "name": "i_paths",
            "key": "-i",
            "long_key": "--i_paths",
            "nargs": "+",
            "help": "Input file list (.nc)",
            "type": "infile(content_type=DTM_NETCDF_4)&sort_cdi"
        },
        {
            "name": "o_path",
            "key": "-o",
            "long_key": "--o_path",
            "help": "Output file (.nc)",
            "default": "merged_fill.dtm.nc",
            "type": "outfile(content_type=DTM_NETCDF_4)"
        },
        {
            "name": "layers",
            "key": "-l",
            "long_key": "--layers",
            "help": "Activate layers.",
            "type": "layers"
        },
        {
            "name": "coord",
            "key": "-c",
            "long_key": "--coord",
            "help": "Coordinates of geographic bounds",
            "type": "geobox#coords"
        },
        {
            "name": "mask",
            "key": "-m",
            "long_key": "--mask",
            "help": "Mask file list (*.kml or *.shp)",
            "nargs": "+",
            "type": "file(content_type=KML_XML|SHAPEFILE)"
        },
        {
            "name": "overwrite",
            "key": "-ow",
            "long_key": "--overwrite",
            "help": "Allow to overwrite file if already exists.",
            "type": "outfile#overwrite"
        },
        {
            "name": "smoothing_border",
            "key": "-sb",
            "long_key": "--smoothing_border",
            "help": "Width of the smoothing border",
            "type": "int[0, 20]"
        },
        {
            "name": "interpolate_border",
            "help": "Interpolate the smoothing border",
            "type": "bool",
            "value": "true"
        },
        {
            "name": "allow_undefined_cdi",
            "key": "-u_cdi",
            "long_key": "--allow_undefined_cdi",
            "help": "Allow valid cells without CDI",
            "type": "bool"
        }
    ]
}
