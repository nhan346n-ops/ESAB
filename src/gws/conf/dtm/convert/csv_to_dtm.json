{
    "name": "Point Cloud CSV to DTM",
    "function": "pyat.dtm.convert.csv_to_dtm.CsvToDtm",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/dtm/convert/csv_to_dtm.html",
    "pages": [
        {
            "title": "Metadata",
            "description": "Define metadata to complete the output DTM",
            "parameters": [
                "title",
                "institution",
                "source",
                "references",
                "comment"
            ]
        }
    ],
    "parameters": [
        {
            "name": "i_paths",
            "key": "-i",
            "long_key": "--i_paths",
            "help": "Input CSV file",
            "nargs": "*",
            "type": "infile(content_type=BATHIMETRIC_CSV|POINT_CLOUD_CSV,extensions=txt|asc)"
        },
        {
            "name": "o_paths",
            "key": "-o",
            "long_key": "--o_paths",
            "help": "Output file (.dtm.nc)",
            "nargs": "1",
            "type": "outfile(content_type=DTM_NETCDF_4)"
        },
        {
            "name": "mandatory_headers",
            "type": "csv#mandatory_headers(restore=false)",
            "nargs": "+",
            "default": [
                "Longitude/X",
                "Latitude/Y",
                "Elevation"
            ]
        },
        {
            "name": "headers_types",
            "type": "csv#headers_types(restore=false)",
            "nargs": "+",
            "default": {
                "Longitude/X": "float",
                "Latitude/Y": "float",
                "Elevation": "float",
                "CDI": "str",
                "Min elevation": "float",
                "Max elevation": "float",
                "Elevation smoothed": "float",
                "Backscatter": "float",
                "Interpolation flag": "int",
                "Std dev": "float"
            }
        },
        {
            "name": "indexes",
            "type": "csv#indexes(restore=false)",
            "nargs": "+",
            "key": "-i",
            "long_key": "--indexes",
            "help": "indexes in the CSV file of each column header",
            "default": {
                "Longitude/X": "0",
                "Latitude/Y": "1",
                "Elevation": "2"
            }
        },
        {
            "name": "delimiter",
            "type": "csv#delimiter(restore=false)",
            "key": "-d",
            "long_key": "--delimiter",
            "help": "Column delimiter",
            "default": ";"
        },
        {
            "name": "decimal_point",
            "type": "csv#decimalpoint(restore=false)",
            "key": "-dp",
            "long_key": "--decimal_point",
            "help": "Decimal point",
            "default": "."
        },
        {
            "name": "skip_rows",
            "type": "csv#skiprows(restore=false)",
            "key": "-sk",
            "long_key": "--skiprows",
            "help": "Number of lines to skip at the start of the file",
            "default": 0
        },
        {
            "name": "depth_sign",
            "type": "csv#depthsign(restore=false)",
            "key": "-ds",
            "long_key": "--depthsign",
            "help": "-1 for elevation values and 1 for depth",
            "default": 1
        },
        {
            "name": "spatial_reference",
            "type": "projection(restore=false)",
            "key": "-s_srs",
            "long_key": "--spatial_reference",
            "help": "Set spatial reference as a PROJ.4 declarations"
        },
        {
            "name": "coord",
            "key": "-c",
            "long_key": "--coord",
            "help": "Coordinates of geographic bounds",
            "type": "geobox#coords(restore=false)",
            "function": "functions/evaluate_csv_geobox.json"
        },
        {
            "name": "target_resolution",
            "type": "geobox#resolution(restore=false)",
            "key": "-tr",
            "long_key": "--target_resolution",
            "help": "Set output file resolution (in target georeferenced units)."
        },
        {
            "name": "auto_layers",
            "key": "-al",
            "long_key": "--auto_layers",
            "help": "Select optional layers to generate. Layer elevation is exported by default",
            "type": "checklist",
            "choices": [
                "elevation_min",
                "elevation_max",
                "stdev",
                "value_count",
                "filtered_sounding"
            ],
            "default": null
        },
        {
            "name": "gap_filling",
            "type": "mask#enable",
            "key": "-gf",
            "long_key": "--call_gap_filling",
            "help": "Fill gap after computation",
            "default": false
        },
        {
            "name": "mask_size",
            "type": "mask#size",
            "key": "-ms",
            "long_key": "--mask_size",
            "default": 3
        },
        {
            "name": "mask",
            "type": "mask#files",
            "key": "-m",
            "long_key": "--mask"
        },
        {
            "name": "cdi",
            "key": "-c",
            "long_key": "--cdi",
            "help": "Name of the CDI to set on all valid cell",
            "type": "cdi#set",
            "nargs": "+"
        },
        {
            "name": "spatial_antialiasing",
            "type": "bool",
            "key": "-saa",
            "long_key": "--spatial_antialiasing",
            "help": "Apply spatial antialiasing (bilinear interpolation on cell centroids).",
            "default": false
        },
        {
            "name": "min_elevation",
            "type": "float",
            "key": "-minE",
            "long_key": "--min_elevation",
            "help": "Minimal elevation (m) for Z soundings min-max filter.",
            "default": null
        },
        {
            "name": "max_elevation",
            "type": "float",
            "key": "-maxE",
            "long_key": "--max_elevation",
            "help": "Maximal elevation (m) for Z soundings min-max filter.",
            "default": null
        },
        {
            "name": "min_sounds",
            "type": "int",
            "key": "-iso",
            "long_key": "--minimum_sounds",
            "help": "Minimum sounding expected to compute a cell",
            "default": null
        },
        {
            "name": "allow_undefined_cdi",
            "key": "-u_cdi",
            "long_key": "--allow_undefined_cdi",
            "help": "Allow valid cells without CDI",
            "type": "bool"
        },
        {
            "name": "title",
            "type": "string",
            "key": "-tit",
            "long_key": "--title",
            "help": "Title",
            "default": ""
        },
        {
            "name": "institution",
            "type": "string",
            "key": "-ins",
            "long_key": "--institution",
            "help": "Institution",
            "default": ""
        },
        {
            "name": "source",
            "type": "string",
            "key": "-sco",
            "long_key": "--source",
            "help": "Source",
            "default": ""
        },
        {
            "name": "references",
            "type": "string",
            "key": "-ref",
            "long_key": "--references",
            "help": "References",
            "default": ""
        },
        {
            "name": "comment",
            "type": "string",
            "key": "-com",
            "long_key": "--comment",
            "help": "Comment",
            "default": ""
        },
        {
            "name": "overwrite",
            "key": "-ow",
            "long_key": "--overwrite",
            "help": "Allow to overwrite file if already exists.",
            "type": "outfile#overwrite"
        }
    ]
}
