{
    "name": "Raster file (TIFF...) to DTM",
    "function": "pyat.dtm.convert.gdal_raster_to_dtm.export_gdal_raster_to_dtm",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/dtm/convert/raster_to_dtm.html",
    "parameters": [
        {
            "name": "i_paths",
            "key": "-i",
            "long_key": "--i_paths",
            "help": "Input file list (any raster file accepted by GDAL)",
            "nargs": "+",
            "type": "infile(content_type=RASTER_GDAL)"
        },
        {
            "name": "o_paths",
            "key": "-o",
            "long_key": "--o_paths",
            "help": "Output file list (.dtm.nc)",
            "nargs": "+",
            "type": "outfile(extensions=dtm.nc)"
        },
        {
            "name": "title",
            "type": "string",
            "key": "-tit",
            "long_key": "--title",
            "help": "Title",
            "default": ""
        },
        {
            "name": "institution",
            "type": "string",
            "key": "-ins",
            "long_key": "--institution",
            "help": "Institution",
            "default": ""
        },
        {
            "name": "source",
            "type": "string",
            "key": "-sco",
            "long_key": "--source",
            "help": "Source",
            "default": ""
        },
        {
            "name": "references",
            "type": "string",
            "key": "-ref",
            "long_key": "--references",
            "help": "References",
            "default": ""
        },
        {
            "name": "comment",
            "type": "string",
            "key": "-com",
            "long_key": "--comment",
            "help": "Comment",
            "default": ""
        },
        {
            "name": "overwrite",
            "key": "-ow",
            "long_key": "--overwrite",
            "help": "Allow to overwrite file if already exists.",
            "type": "outfile#overwrite"
        },
        {
            "name": "remove_invalid_elevation",
            "key": "-rae",
            "help": "Remove elevation values above 32000m or below -32000m",
            "type": "bool",
            "default": "True"
        }
    ]
}
