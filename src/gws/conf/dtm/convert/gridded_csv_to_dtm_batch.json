{
    "name": "Gridded CSV to DTM (batch mode)",
    "function": "pyat.dtm.convert.gridded_csv_to_dtm.GriddedCsvToDtm",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/dtm/convert/gridded_csv_to_dtm_batch.html",
    "pages": [
        {
            "title": "Masked arguments",
            "visible": false,
            "parameters": [
                "recompute_geobox"
            ]
        },
        {
            "title": "Geobox override parameters",
            "description": "How to manage the Geobox",
            "parameters": [
                "auto_rounding_arcmin",
                "pos_in_cell"
            ]
        },
        {
            "title": "Metadata",
            "description": "Define metadata to complete the output DTM",
            "parameters": [
                "title",
                "institution",
                "source",
                "references",
                "comment"
            ]
        }
    ],
    "parameters": [
        {
            "name": "i_paths",
            "key": "-i",
            "long_key": "--i_paths",
            "help": "Input CSV file list",
            "nargs": "+",
            "type": "infile(content_type=BATHIMETRIC_CSV|EMO_CSV,extensions=asc)"
        },
        {
            "name": "o_paths",
            "key": "-o",
            "long_key": "--o_paths",
            "help": "Output file list (.dtm.nc)",
            "nargs": "+",
            "type": "outfile(content_type=DTM_NETCDF_4)"
        },
        {
            "name": "mandatory_headers",
            "type": "csv#mandatory_headers",
            "nargs": "+",
            "default": [
                "Longitude/X",
                "Latitude/Y",
                "Elevation"
            ]
        },
        {
            "name": "optional_headers",
            "type": "csv#optional_headers",
            "nargs": "+",
            "default": [
                "CDI",
                "CPRD",
                "Min elevation",
                "Max elevation",
                "Elevation smoothed",
                "Value count",
                "Backscatter",
                "Interpolation flag",
                "Std dev"
            ]
        },
        {
            "name": "headers_types",
            "type": "csv#headers_types",
            "nargs": "+",
            "default": {
                "Longitude/X": "float",
                "Latitude/Y": "float",
                "Elevation": "float",
                "CDI": "str",
                "Min elevation": "float",
                "Max elevation": "float",
                "Elevation smoothed": "float",
                "Value count": "int",
                "Backscatter": "float",
                "Interpolation flag": "int",
                "Std dev": "float",
                "CPRD": "str"
            }
        },
        {
            "name": "indexes",
            "type": "csv#indexes",
            "nargs": "+",
            "key": "-i",
            "long_key": "--indexes",
            "help": "indexes in the CSV file of each column header",
            "default": {
                "Longitude/X": "0",
                "Latitude/Y": "1",
                "Elevation": "2"
            }
        },
        {
            "name": "delimiter",
            "type": "csv#delimiter",
            "key": "-d",
            "long_key": "--delimiter",
            "help": "Column delimiter",
            "default": ";"
        },
        {
            "name": "decimal_point",
            "type": "csv#decimalpoint",
            "key": "-dp",
            "long_key": "--decimal_point",
            "help": "Decimal point",
            "default": "."
        },
        {
            "name": "skip_rows",
            "type": "csv#skiprows",
            "key": "-sk",
            "long_key": "--skiprows",
            "help": "Number of lines to skip at the start of the file",
            "default": 0
        },
        {
            "name": "depth_sign",
            "type": "csv#depthsign",
            "key": "-ds",
            "long_key": "--depthsign",
            "help": "-1 for elevation values and 1 for depth",
            "default": 1
        },
        {
            "name": "spatial_reference",
            "type": "projection(restore=false)",
            "key": "-s_srs",
            "long_key": "--spatial_reference",
            "help": "Set spatial reference as a PROJ.4 declarations"
        },
        {
            "name": "recompute_geobox",
            "type": "bool",
            "help": "Ignore bounding box definition and recompute it for each input file",
            "default": true
        },
        {
            "name": "auto_rounding_arcmin",
            "type": "bool",
            "key": "-ea",
            "long_key": "--auto_rounding_arcmin",
            "help": "Expands bounding boxes to arcmin",
            "default": true
        },
        {
            "name": "pos_in_cell",
            "type": "string",
            "key": "-pic",
            "long_key": "--position_in_cell",
            "choices": [
                "center",
                "upper-left",
                "upper-right",
                "lower-left",
                "lower-right"
            ],
            "help": "Position of values in the cells of the source grid",
            "default": "center"
        },
        {
            "name": "title",
            "type": "string",
            "key": "-tit",
            "long_key": "--title",
            "help": "Title",
            "default": ""
        },
        {
            "name": "institution",
            "type": "string",
            "key": "-ins",
            "long_key": "--institution",
            "help": "Institution",
            "default": ""
        },
        {
            "name": "source",
            "type": "string",
            "key": "-sco",
            "long_key": "--source",
            "help": "Source",
            "default": ""
        },
        {
            "name": "references",
            "type": "string",
            "key": "-ref",
            "long_key": "--references",
            "help": "References",
            "default": ""
        },
        {
            "name": "comment",
            "type": "string",
            "key": "-com",
            "long_key": "--comment",
            "help": "Comment",
            "default": ""
        },
        {
            "name": "overwrite",
            "key": "-ow",
            "long_key": "--overwrite",
            "help": "Allow to overwrite file if already exists.",
            "type": "outfile#overwrite"
        },
        {
            "name": "allow_undefined_cdi",
            "key": "-u_cdi",
            "long_key": "--allow_undefined_cdi",
            "help": "Allow valid cells without CDI",
            "type": "bool"
        }
    ]
}
