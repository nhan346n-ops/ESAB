{
    "name": "Gridded CSV to DTM",
    "function": "pyat.dtm.convert.gridded_csv_to_dtm.GriddedCsvToDtm",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/dtm/convert/gridded_csv_to_dtm.html",
    "pages": [
        {
            "title": "Metadata",
            "description": "Define metadata to complete the output DTM",
            "parameters": [
                "title",
                "institution",
                "source",
                "references",
                "comment"
            ]
        }
    ],
    "parameters": [
        {
            "name": "i_paths",
            "key": "-i",
            "long_key": "--i_paths",
            "help": "Input CSV file",
            "nargs": "1",
            "type": "infile(content_type=BATHIMETRIC_CSV|EMO_CSV,extensions=asc)"
        },
        {
            "name": "o_paths",
            "key": "-o",
            "long_key": "--o_paths",
            "help": "Output file (.dtm.nc)",
            "nargs": "1",
            "type": "outfile(content_type=DTM_NETCDF_4)"
        },
        {
            "name": "mandatory_headers",
            "type": "csv#mandatory_headers",
            "nargs": "+",
            "default": [
                "Longitude/X",
                "Latitude/Y",
                "Elevation"
            ]
        },
        {
            "name": "optional_headers",
            "type": "csv#optional_headers",
            "nargs": "+",
            "default": [
                "CDI",
                "CPRD",
                "Min elevation",
                "Max elevation",
                "Elevation smoothed",
                "Value count",
                "Backscatter",
                "Interpolation flag",
                "Std dev"
            ]
        },
        {
            "name": "headers_types",
            "type": "csv#headers_types",
            "nargs": "+",
            "default": {
                "Longitude/X": "float",
                "Latitude/Y": "float",
                "Elevation": "float",
                "CDI": "str",
                "Min elevation": "float",
                "Max elevation": "float",
                "Elevation smoothed": "float",
                "Value count": "int",
                "Backscatter": "float",
                "Interpolation flag": "int",
                "Std dev": "float",
                "CPRD": "str"
            }
        },
        {
            "name": "indexes",
            "type": "csv#indexes",
            "nargs": "+",
            "key": "-i",
            "long_key": "--indexes",
            "help": "indexes in the CSV file of each column header",
            "default": {
                "Longitude/X": "0",
                "Latitude/Y": "1",
                "Elevation": "2"
            }
        },
        {
            "name": "delimiter",
            "type": "csv#delimiter",
            "key": "-d",
            "long_key": "--delimiter",
            "help": "Column delimiter",
            "default": ";"
        },
        {
            "name": "decimal_point",
            "type": "csv#decimalpoint",
            "key": "-dp",
            "long_key": "--decimal_point",
            "help": "Decimal point",
            "default": "."
        },
        {
            "name": "skip_rows",
            "type": "csv#skiprows",
            "key": "-sk",
            "long_key": "--skiprows",
            "help": "Number of lines to skip at the start of the file",
            "default": 0
        },
        {
            "name": "depth_sign",
            "type": "csv#depthsign",
            "key": "-ds",
            "long_key": "--depthsign",
            "help": "-1 for elevation values and 1 for depth",
            "default": 1
        },
        {
            "name": "spatial_reference",
            "type": "projection(restore=false)",
            "key": "-s_srs",
            "long_key": "--spatial_reference",
            "help": "Set spatial reference as a PROJ.4 declarations"
        },
        {
            "name": "coord",
            "key": "-c",
            "long_key": "--coord",
            "help": "Coordinates of geographic bounds",
            "type": "geobox#coords(restore=false)",
            "function": "functions/evaluate_csv_geobox_and_spatial_resolution.json"
        },
        {
            "name": "target_resolution",
            "type": "geobox#resolution(restore=false)",
            "key": "-tr",
            "long_key": "--target_resolution",
            "help": "Set output file resolution (in target georeferenced units)."
        },
        {
            "name": "title",
            "type": "string",
            "key": "-tit",
            "long_key": "--title",
            "help": "Title",
            "default": ""
        },
        {
            "name": "institution",
            "type": "string",
            "key": "-ins",
            "long_key": "--institution",
            "help": "Institution",
            "default": ""
        },
        {
            "name": "source",
            "type": "string",
            "key": "-sco",
            "long_key": "--source",
            "help": "Source",
            "default": ""
        },
        {
            "name": "references",
            "type": "string",
            "key": "-ref",
            "long_key": "--references",
            "help": "References",
            "default": ""
        },
        {
            "name": "comment",
            "type": "string",
            "key": "-com",
            "long_key": "--comment",
            "help": "Comment",
            "default": ""
        },
        {
            "name": "overwrite",
            "key": "-ow",
            "long_key": "--overwrite",
            "help": "Allow to overwrite file if already exists.",
            "type": "outfile#overwrite"
        },
        {
            "name": "allow_undefined_cdi",
            "key": "-u_cdi",
            "long_key": "--allow_undefined_cdi",
            "help": "Allow valid cells without CDI",
            "type": "bool"
        }
    ]
}
