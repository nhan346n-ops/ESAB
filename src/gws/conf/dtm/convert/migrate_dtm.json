{
    "name": "Upgrade DTM format",
    "function": "pyat.dtm.convert.migrate_dtm_process.DTMMigrate",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/dtm/convert/migrate_dtm.html",
    "parameters": [
        {
            "name": "i_paths",
            "key": "-i",
            "long_key": "--i_paths",
            "help": "Input file list (.dtm)",
            "nargs": "+",
            "type": "infile(content_type=DTM_NETCDF_3,extensions=dtm|mnt)"
        },
        {
            "name": "o_paths",
            "key": "-o",
            "long_key": "--o_paths",
            "help": "Output file list (.nc)",
            "nargs": "+",
            "type": "outfile(content_type=DTM_NETCDF_4)"
        },
        {
            "name": "overwrite",
            "key": "-ow",
            "long_key": "--overwrite",
            "help": "Allow to overwrite file if already exists.",
            "type": "outfile#overwrite"
        }
    ]
}
