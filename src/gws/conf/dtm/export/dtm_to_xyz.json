{
    "name": "Export DTM to XYZ",
    "function": "pyat.dtm.export.dtm_to_ascii.Dtm2Ascii",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/dtm/export/dtm_to_xyz.html",
    "parameters": [
        {
            "name": "i_paths",
            "key": "-i",
            "long_key": "--i_paths",
            "help": "Input file list (*.dtm.nc)",
            "nargs": "+",
            "type": "infile(content_type=DTM_NETCDF_4)"
        },
        {
            "name": "o_paths",
            "key": "-o",
            "long_key": "--o_paths",
            "help": "Output file list (*.xyz)",
            "nargs": "+",
            "type": "outfile(extension=xyz)"
        },
        {
            "name": "overwrite",
            "key": "-ow",
            "long_key": "--overwrite",
            "help": "Allow to overwrite file if already exists.",
            "type": "outfile#overwrite"
        },
        {
            "name": "export_missing_values",
            "key": "-miss",
            "long_key": "--export_missing_values",
            "help": "Export missing values, if true export data even when bathymetry is invalid",
            "type": "bool",
            "default": "False"
        },
        {
            "name": "column_separator",
            "type": "string",
            "choices": [
                "Semicolon",
                "Comma",
                "Space",
                "Tabulation",
                "Other"
            ],
            "default": "Semicolon",
            "help": "Column separator"
        },
        {
            "name": "other_separator",
            "type": "string",
            "default": ";",
            "help": "Other separator (if 'Other' selected)"
        },
        {
            "name": "decimal_separator",
            "type": "string",
            "choices": [
                "Dot",
                "Comma"
            ],
            "default": "Dot",
            "help": "Decimal separator"
        },
        {
            "name": "column_order",
            "type": "string",
            "choices": [
                "XYZ",
                "XZY",
                "YXZ",
                "YZX",
                "ZXY",
                "ZYX"
            ],
            "default": "XYZ",
            "help": "Column order"
        }
    ]
}
