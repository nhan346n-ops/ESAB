{
    "name": "Export DTM to isobath",
    "function": "pyat.dtm.export.dtm_to_isobath.Dtm2Isobath",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/dtm/export/dtm_to_isobath.html",
    "parameters": [
        {
            "name": "i_paths",
            "key": "-i",
            "long_key": "--i_paths",
            "help": "Input file list (*.dtm.nc)",
            "nargs": "+",
            "type": "infile(content_type=DTM_NETCDF_4)"
        },
        {
            "name": "o_paths",
            "key": "-o",
            "long_key": "--o_paths",
            "help": "Output file list (.shp)",
            "nargs": "+",
            "type": "outfile(extensions=gpkg|kml|shp)"
        },
        {
            "name": "overwrite",
            "key": "-ow",
            "long_key": "--overwrite",
            "help": "Allow to overwrite file if already exists.",
            "type": "outfile#overwrite"
        },
        {
            "name": "isobath_interval",
            "type": "float",
            "key": "-isobath_interval",
            "long_key": "--isobath_interval",
            "help": "Isobath interval (m)",
            "default": 50
        }
    ]
}

    