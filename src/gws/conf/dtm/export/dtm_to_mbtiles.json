{
    "name": "Export DTM to MBtiles",
    "function": "pyat.dtm.export.dtm_to_mbtiles.Dtm2Mbtiles",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/dtm/export/dtm_to_mbtiles.html",
    "pages": [
        {
            "title": "Hillshading",
            "description": "Optional hillshade parameters",            
            "parameters": [
                "azimuth",
                "altitude",
                "zfactor"
            ]
        },
        {
            "title": "Isobath",
            "description": "Optional isobath overlay parameters",            
            "parameters": [
                "add_isobath",
                "isobath_interval"
            ]
        }
    ],
    "parameters": [
        {
            "name": "i_paths",
            "key": "-i",
            "long_key": "--i_paths",
            "help": "Input file list (*.dtm.nc)",
            "nargs": "+",
            "type": "infile(content_type=DTM_NETCDF_4)"
        },
        {
            "name": "o_paths",
            "key": "-o",
            "long_key": "--o_paths",
            "help": "Output file list (.mbtiles)",
            "nargs": "+",
            "type": "outfile(extension=mbtiles)"
        },
        {
            "name": "overwrite",
            "key": "-ow",
            "long_key": "--overwrite",
            "help": "Allow to overwrite file if already exists.",
            "type": "outfile#overwrite"
        },
        {
            "name": "azimuth",
            "type": "float",
            "key": "-az",
            "long_key": "--azimuth",
            "help": "Sun azimuth (deg)",
            "default": 315
        },
        {
            "name": "altitude",
            "type": "float",
            "key": "-alt",
            "long_key": "--altitude",
            "help": "Sun altitude (90 deg : above, 0 deg: raking)",
            "default": 45
        },
        {
            "name": "zfactor",
            "type": "float",
            "key": "-zf",
            "long_key": "--zfactor",
            "help": "Vertical exaggeration",    
            "default": 1
        },
        {
            "name": "add_isobath",
            "key": "-add_isobath",
            "long_key": "--add_isobath",
            "help": "add isobath overlay",
            "type": "bool",
            "default": false
        },
        {
            "name": "isobath_interval",
            "type": "float",
            "key": "-isobath_interval",
            "long_key": "--isobath_interval",
            "help": "Isobath interval (m)",
            "default": 10
        }
    ]
}
