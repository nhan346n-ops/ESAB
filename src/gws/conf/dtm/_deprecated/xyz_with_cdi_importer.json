{
    "name": "XYZ with CDI importer",
    "function": "pyat.xyz.xyz2dtm.Xyz2Dtm",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/dtm/_deprecated/xyz_with_cdi_importer.html",
    "parameters": [
        {
            "name": "i_paths",
            "key": "-i",
            "long_key": "--i_paths",
            "nargs": "+",
            "help": "Input file list (.xyz)",
            "type": "infile(content_type=BATHIMETRIC_CSV,extensions=xyz|txt|asc)"
        },
        {
            "name": "o_paths",
            "key": "-o",
            "long_key": "--o_paths",
            "help": "Output file list (*.dtm.nc)",
            "nargs": "+",
            "type": "outfile(content_type=DTM_NETCDF_4)"
        },
        {
            "name": "coord",
            "key": "-c",
            "long_key": "--coord",
            "help": "Coordinates of geographic bounds",
            "type": "geobox#coords"
        },
        {
            "name": "target_resolution",
            "type": "geobox#resolution",
            "key": "-tr",
            "long_key": "--target_resolution",
            "help": "Set output file resolution (in target georeferenced units).",
            "default": 0.000277778
        },
        {
            "name": "cdi",
            "key": "-c",
            "long_key": "--cdi",
            "help": "Name of the futur cdi",
            "type": "cdi#set"
        },
        {
            "name": "overwrite",
            "key": "-ow",
            "long_key": "--overwrite",
            "help": "Allow to overwrite file if already exists.",
            "type": "outfile#overwrite"
        }
    ]
}
