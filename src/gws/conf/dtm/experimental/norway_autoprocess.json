{
    "name": "Norways Automatic Processing (prototype)",
    "function": "pyat.dtm.experimental.norway_autoprocess.NorwayAutoProcess",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/dtm/experimental/norway_autoprocess.html",
    "parameters": [
        {
            "name": "i_paths",
            "key": "-i",
            "long_key": "--i_paths",
            "nargs": "*",
            "help": "input file list",
            "type": "infile(content_type=UNDEFINED)"
        },
        {
            "name": "cdi_file",
            "key": "-c",
            "long_key": "--cid_file",
            "nargs": "1",
            "help": "cdi input file list",
            "type": "infile(content_type=csv)"
        },
        {
            "name": "o_paths",
            "key": "-o",
            "long_key": "--o_paths",
            "nargs": "+",
            "help": "Output file list (*.nc)",
            "type": "outfile(content_type=DTM_NETCDF_4,suffix=cdi)"
        },
        {
            "name": "overwrite",
            "key": "-ow",
            "long_key": "--overwrite",
            "help": "Allow to overwrite file if already exists.",
            "type": "outfile#overwrite"
        }
    ]
}
