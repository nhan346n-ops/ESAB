{
    "name": "Linear Transform",
    "function": "pyat.dtm.transform.linear_transform.LinearTransformProcess",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/dtm/transform/linear_transform.html",
    "parameters": [
        {
            "name": "i_paths",
            "key": "-i",
            "long_key": "--i_paths",
            "nargs": "+",
            "help": "Input file list (*.nc)",
            "type": "infile(content_type=DTM_NETCDF_4)"
        },
        {
            "name": "o_paths",
            "key": "-o",
            "long_key": "--o_paths",
            "nargs": "+",
            "help": "Output file list (*.nc)",
            "type": "outfile(content_type=DTM_NETCDF_4,suffix=linear_transform)"
        },
        {
            "name": "a",
            "type": "float",
            "key": "-a",
            "long_key": "--a",
            "help": "Multiplicator",
            "default": 1.0
        },
        {
            "name": "b",
            "type": "float",
            "key": "-b",
            "long_key": "--b",
            "help": "Adder",
            "default": 0.0
        },
        {
            "name": "mask",
            "key": "-m",
            "long_key": "--mask",
            "help": "Mask file list (*.kml or *.shp)",
            "nargs": "+",
            "type": "file(content_type=KML_XML|SHAPEFILE)"
        },
        {
            "name": "overwrite",
            "key": "-ow",
            "long_key": "--overwrite",
            "help": "Allow to overwrite file if already exists.",
            "type": "outfile#overwrite"
        }
    ]
}
