{
    "name": "Set Interpolated",
    "function": "pyat.dtm.transform.set_interpolated.SetInterpolatedProcess",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/dtm/transform/set_interpolated.html",
    "parameters": [
        {
            "name": "i_paths",
            "key": "-i",
            "long_key": "--i_paths",
            "nargs": "+",
            "help": "Input file list (*.nc)",
            "type": "infile(content_type=DTM_NETCDF_4)"
        },
        {
            "name": "o_paths",
            "key": "-o",
            "long_key": "--o_paths",
            "nargs": "+",
            "help": "Output file list (*.nc)",
            "type": "outfile(content_type=DTM_NETCDF_4,suffix=set_interpolated)"
        },
        {
            "name": "mask",
            "key": "-m",
            "long_key": "--mask",
            "help": "Mask file list (*.kml or *.shp)",
            "nargs": "+",
            "type": "file(content_type=KML_XML|SHAPEFILE)"
        },
        {
            "name": "overwrite",
            "key": "-ow",
            "long_key": "--overwrite",
            "help": "Allow to overwrite file if already exists.",
            "type": "outfile#overwrite"
        }
    ]
}
