{
    "name": "AMLE interpolation (Coronis)",
    "function": "pyat.dtm.transform.interpolation.coronis.amle_interpolation.AmleInterpolationProcessAdapter",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/dtm/transform/interpolation/coronis/amle_interpolation.html",
    "pages": [
        {
            "title": "AMLE interpolation parameters",
            "parameters": [
                "areas",
                "cdi_interpolation_algo",
                "update_step_size",
                "term_crit",
                "term_thres",
                "term_check_iters",
                "max_iters",
                "relaxation",
                "print_progress_iters",
                "mgs_levels",
                "mgs_min_res",
                "init_with",
                "convolver",
                "convolve_in_1d"
            ]
        },
        {
            "title": "Feedback parameters",
            "parameters": [
                "verbose",
                "show"
            ]
        }
    ],
    "parameters": [
        {
            "name": "i_paths",
            "key": "-i",
            "long_key": "--i_paths",
            "nargs": "+",
            "help": "Input file list (*.nc)",
            "type": "infile(content_type=DTM_NETCDF_4)"
        },
        {
            "name": "o_paths",
            "key": "-o",
            "long_key": "--o_paths",
            "nargs": "+",
            "help": "Output file list (*.nc)",
            "type": "outfile(content_type=DTM_NETCDF_4,suffix=amle_interpolated)"
        },
        {
            "name": "overwrite",
            "key": "-ow",
            "long_key": "--overwrite",
            "help": "Allow to overwrite file if already exists.",
            "type": "outfile#overwrite"
        },
        {
            "name": "areas",
            "key": "-areas",
            "help": "KML file containing the areas that will be interpolated",
            "type": "file(content_type=KML_XML)"
        },
        {
            "name": "cdi_interpolation_algo",
            "key": "-cdi",
            "help": "CDI filling algorithm",
            "type": "string",
            "choices": [
                "closest_neighbor",
                "most_common_neighbor"
            ],
            "default": "closest_neighbor"
        },
        {
            "name": "update_step_size",
            "type": "float",
            "key": "-update_step_size",
            "help": "Update step size.",
            "default": 0.001
        },
        {
            "name": "term_thres",
            "type": "float",
            "key": "-term_thres",
            "help": "If the relative change between the inpainted elevations in the current and a previous step is smaller than this value, the optimization will stop.",
            "default": 1e-7
        },
        {
            "name": "term_crit",
            "type": "string",
            "key": "-term_crit",
            "choices": [
                "relative",
                "absolute",
                "absolute_percent"
            ],
            "help": "The termination criteria to use.",
            "default": "absolute_percent"
        },
        {
            "name": "term_check_iters",
            "type": "int[1,2147483647]",
            "key": "-term_check_iters",
            "help": "Number of iterations in the optimization after which we will check if the relative tolerance is below the threshold",
            "default": 1000
        },
        {
            "name": "max_iters",
            "type": "int[1,2147483647]",
            "key": "-max_iters",
            "help": "Maximum number of iterations in the optimization",
            "default": 1000000
        },
        {
            "name": "relaxation",
            "type": "float",
            "key": "-relaxation",
            "help": "Set to >1 to perform over-relaxation at each iteration",
            "default": 0
        },
        {
            "name": "print_progress_iters",
            "type": "int[1,2147483647]",
            "key": "-print_progress_iters",
            "help": "If '--print_progress True', the optimization progress will be shown after this number of iterations",
            "default": 1000
        },
        {
            "name": "mgs_levels",
            "type": "int[1,2147483647]",
            "key": "-mgs_levels",
            "help": "Levels of the Multi-grid solver. I.e., number of levels of detail used in the solving pyramid",
            "default": 1
        },
        {
            "name": "mgs_min_res",
            "type": "int[1,2147483647]",
            "key": "-mgs_min_res",
            "help": "If during the construction of the pyramid of the Multi-Grid Solver one of the dimensions of the grid drops below this size, the pyramid construction will stop at that level",
            "default": 100
        },
        {
            "name": "init_with",
            "type": "string",
            "key": "-init_with",
            "choices": [
                "zeros",
                "mean",
                "nearest",
                "linear",
                "cubic",
                "sobolev"
            ],
            "help": "Initialize the unknown values to inpaint using a simple interpolation function. If using a MGS, this will be used with the lowest level on the pyramid.",
            "default": "nearest"
        },
        {
            "name": "convolver",
            "type": "string",
            "key": "-convolver",
            "choices": [
                "opencv",
                "scipy-signal",
                "scipy-ndimage",
                "masked",
                "masked-parallel"
            ],
            "help": "The convolution method to use.",
            "default": "opencv"
        },
        {
            "name": "convolve_in_1d",
            "type": "bool",
            "key": "-convolve_in_1d",
            "help": "Perform 1D convolutions instead of using the 2D convolution",
            "default": true
        },
        {
            "name": "verbose",
            "type": "bool",
            "key": "-verbose",
            "help": "Verbosity flag, activate it to have feedback of the current steps of the process in the command line.",
            "default": false
        },
        {
            "name": "show",
            "type": "bool",
            "key": "-show",
            "help": "Show interpolation problem and results on screen.",
            "default": false
        }
    ]
}
