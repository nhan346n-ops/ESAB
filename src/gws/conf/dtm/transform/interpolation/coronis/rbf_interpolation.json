{
    "name": "RBF interpolation (Coronis)",
    "function": "pyat.dtm.transform.interpolation.coronis.rbf_interpolation.RbfInterpolationProcessAdapter",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/dtm/transform/interpolation/coronis/rbf_interpolation.html",
    "pages": [
        {
            "title": "Radial Basis Function interpolation parameters",
            "parameters": [
                "areas",
                "cdi_interpolation_algo",
                "query_block_size",
                "rbf_distance_type",
                "rbf_type",
                "rbf_epsilon",
                "rbf_regularization",
                "rbf_polynomial_degree"
            ]
        },
        {
            "title": "Feedback parameters",
            "parameters": [
                "verbose",
                "show"
            ]
        }
    ],
    "parameters": [
        {
            "name": "i_paths",
            "key": "-i",
            "long_key": "--i_paths",
            "nargs": "+",
            "help": "Input file list (*.nc)",
            "type": "infile(content_type=DTM_NETCDF_4)"
        },
        {
            "name": "o_paths",
            "key": "-o",
            "long_key": "--o_paths",
            "nargs": "+",
            "help": "Output file list (*.nc)",
            "type": "outfile(content_type=DTM_NETCDF_4,suffix=rbf_interpolated)"
        },
        {
            "name": "overwrite",
            "key": "-ow",
            "long_key": "--overwrite",
            "help": "Allow to overwrite file if already exists.",
            "type": "outfile#overwrite"
        },
        {
            "name": "areas",
            "key": "-areas",
            "help": "KML file containing the areas that will be interpolated",
            "type": "file(content_type=KML_XML)"
        },
        {
            "name": "cdi_interpolation_algo",
            "key": "-cdi",
            "help": "CDI filling algorithm",
            "type": "string",
            "choices": [
                "closest_neighbor",
                "most_common_neighbor"
            ],
            "default": "closest_neighbor"
        },
        {
            "name": "query_block_size",
            "type": "int",
            "default": 1000,
            "key": "-query_block_size",
            "help": "Apply the interpolant using maximum this number of points at a time to avoid large memory consumption."
        },
        {
            "name": "rbf_distance_type",
            "type": "string",
            "key": "-rbf_distance_type",
            "choices": [
                "euclidean",
                "haversine",
                "vincenty"
            ],
            "help": "Distance type",
            "default": "euclidean"
        },
        {
            "name": "rbf_type",
            "type": "string",
            "key": "-rbf_type",
            "choices": [
                "linear",
                "cubic",
                "quintic",
                "gaussian",
                "multiquadric",
                "green",
                "regularized",
                "tension",
                "thinplate",
                "wendland"
            ],
            "help": "RBF type",
            "default": "thinplate"
        },
        {
            "name": "rbf_epsilon",
            "type": "float",
            "key": "-rbf_epsilon",
            "help": "Epsilon parameter of the RBF. Please check each RBF documentation for its meaning. Required just for the following RBF types: gaussian, multiquadric, regularized, tension, wendland",
            "default": 1.0
        },
        {
            "name": "rbf_regularization",
            "type": "float",
            "key": "-rbf_regularization",
            "help": "Regularization scalar to use while creating the RBF interpolant (optional)",
            "default": 0.0
        },
        {
            "name": "rbf_polynomial_degree",
            "type": "int",
            "key": "-rbf_polynomial_degree",
            "choices": [
                "-1",
                "0",
                "1",
                "2",
                "3"
            ],
            "help": "Degree of the global polynomial fit used in the RBF formulation. Valid: -1 (no polynomial fit), 0 (constant), 1 (linear), 2 (quadric), 3 (cubic)",
            "default": 1
        },
        {
            "name": "verbose",
            "type": "bool",
            "key": "-verbose",
            "help": "Verbosity flag, activate it to have feedback of the current steps of the process in the command line.",
            "default": false
        },
        {
            "name": "show",
            "type": "bool",
            "key": "-show",
            "help": "Show interpolation problem and results on screen.",
            "default": false
        }
    ]
}
