{
    "name": "Linear interpolation (Xarray)",
    "function": "pyat.dtm.transform.interpolation.xarray_interpolate.InterpolateProcess",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/dtm/transform/interpolation/xarray_interpolation.html",
    "parameters": [
        {
            "name": "i_paths",
            "key": "-i",
            "long_key": "--i_paths",
            "nargs": "+",
            "help": "Input file list (*.nc)",
            "type": "infile(content_type=DTM_NETCDF_4)"
        },
        {
            "name": "o_paths",
            "key": "-o",
            "long_key": "--o_paths",
            "nargs": "+",
            "help": "Output file list (*.nc)",
            "type": "outfile(content_type=DTM_NETCDF_4,suffix=interpolated)"
        },
        {
            "name": "overwrite",
            "key": "-ow",
            "long_key": "--overwrite",
            "help": "Allow to overwrite file if already exists.",
            "type": "outfile#overwrite"
        },
        {
            "name": "masks",
            "key": "-masks",
            "help": "KML file containing the areas that will be interpolated",
            "type": "file(content_type=KML_XML)"
        },
        {
            "name": "cdi_interpolation_algo",
            "key": "-cdi",
            "help": "CDI filling algorithm",
            "type": "string",
            "choices": [
                "closest_neighbor",
                "most_common_neighbor"
            ],
            "default": "closest_neighbor"
        }
    ]
}
