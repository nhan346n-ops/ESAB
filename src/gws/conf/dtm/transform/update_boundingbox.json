{
    "name": "Reproject and Update Bounding Box",
    "function": "pyat.dtm.transform.update_boundingbox.ReprojectProcess",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/dtm/transform/update_boundingbox.html",
    "parameters": [
        {
            "name": "i_paths",
            "key": "-i",
            "long_key": "--i_paths",
            "nargs": "+",
            "help": "Input file list (.nc)",
            "type": "infile(content_type=DTM_NETCDF_4)"
        },
        {
            "name": "o_paths",
            "key": "-o",
            "long_key": "--o_paths",
            "nargs": "+",
            "help": "Output file list (.nc)",
            "type": "outfile(content_type=DTM_NETCDF_4,suffix=reproject)"
        },
        {
            "name": "target_spatial_reference",
            "type": "projection",
            "key": "-t_srs",
            "long_key": "--target_spatial_reference",
            "help": "Set target spatial reference as a PROJ.4 declarations",
            "default": "+proj=longlat +ellps=WGS84 +datum=WGS84 +no_defs"
        },
        {
            "name": "coord",
            "key": "-c",
            "long_key": "--coord",
            "help": "Coordinates of geographic bounds",
            "type": "geobox#coords"
        },
        {
            "name": "target_resolution",
            "type": "geobox#resolution",
            "key": "-sr",
            "long_key": "--target_resolution",
            "help": "Specified output file resolution (in target spatial reference units).",
            "default": 0.000277778
        },
        {
            "name": "default_algorithm",
            "key": "-da",
            "type": "string",
            "long_key": "--default_algorithm",
            "choices": [
                "near",
                "bilinear",
                "cubic",
                "cubicspline",
                "lanczos",
                "average"
            ],
            "default": "bilinear",
            "help": "default algorithm for all numeric layers (depth,min,max,...)"
        },
        {
            "name": "cdi_algorithm",
            "key": "-cdi",
            "type": "string",
            "long_key": "--cdi_algorithm",
            "choices": [
                "near",
                "mode"
            ],
            "help": "algorithm for cdi layer",
            "default": "mode"
        },
        {
            "name": "stdev_algorithm",
            "key": "-stdev",
            "type": "string",
            "long_key": "--stdev_algorithm",
            "choices": [
                "near",
                "med"
            ],
            "help": "algorithm for stdev layer",
            "default": "near"
        },
        {
            "name": "value_count",
            "key": "-vcount",
            "type": "string",
            "long_key": "--value_count",
            "choices": [
                "near",
                "max",
                "min"
            ],
            "help": "algorithm for value_count layer",
            "default": "near"
        },
        {
            "name": "interpolation_flag",
            "key": "-i_flag",
            "type": "string",
            "long_key": "--interpolation_flag",
            "choices": [
                "near",
                "mode"
            ],
            "help": "algorithm for interpolation_flag layer",
            "default": "near"
        },
        {
            "name": "overwrite",
            "key": "-ow",
            "long_key": "--overwrite",
            "help": "Allow to overwrite file if already exists.",
            "type": "outfile#overwrite"
        }
    ]
}
