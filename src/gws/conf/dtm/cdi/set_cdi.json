{
    "name": "Set CDI",
    "function": "pyat.dtm.cdi.set_cdi_process.SetCdiProcess",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/dtm/cdi/set_cdi.html",
    "parameters": [
        {
            "name": "i_paths",
            "key": "-i",
            "long_key": "--i_paths",
            "nargs": "+",
            "help": "Input file list (.nc)",
            "type": "infile(content_type=DTM_NETCDF_4)"
        },
        {
            "name": "o_paths",
            "key": "-o",
            "long_key": "--o_paths",
            "nargs": "+",
            "help": "Output file list (.nc)",
            "type": "outfile(content_type=DTM_NETCDF_4,suffix=set_cdi)"
        },
        {
            "name": "cdi",
            "key": "-c",
            "long_key": "--cdi",
            "help": "Name of the future cdi",
            "type": "cdi#set",
            "nargs": "+"
        },
        {
            "name": "mask",
            "key": "-m",
            "long_key": "--mask",
            "help": "Mask file list (*.kml or *.shp)",
            "nargs": "+",
            "type": "file(content_type=KML_XML|SHAPEFILE)"
        },
        {
            "name": "cell_without_cdi",
            "type": "bool",
            "key": "-cwc",
            "long_key": "--cell_without_cdi",
            "help": "Limit changes to cells without CDI/CPRD information",
            "default": false
        },
        {
            "name": "overwrite",
            "key": "-ow",
            "long_key": "--overwrite",
            "help": "Allow to overwrite file if already exists.",
            "type": "outfile#overwrite"
        }
    ]
}
