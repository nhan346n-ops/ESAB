{
    "name": "Statistical Angular Response (BSAR)",
    "function": "pyat.sonarscope.bs_correction.stats_computer.compute_mean_model_process",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/sonar/bs/avg_backscatter_model.html",
    "pages": [
        {
            "title": "Advanced options",
            "visible": true,
            "parameters": [
                "sounder_type",
                "use_snippets",
                "use_svp",
                "use_insonified_area",
                "remove_compensation",
                "remove_calibration",
                "integration_method",
                "linear_scale"
            ]
        }
    ],
    "parameters": [
        {
            "name": "i_paths",
            "key": "-in",
            "long_key": "--i_paths",
            "help": "Input files list",
            "nargs": "+",
            "type": "infile(content_type=XSF_NETCDF_4)"
        },
        {
            "name": "o_path",
            "key": "-o",
            "long_key": "--o_path",
            "help": "Backscatter angular response file",
            "type": "outfile(content_type=BSAR_NETCDF_4)"
        },
        {
            "name": "overwrite",
            "key": "-ow",
            "long_key": "--overwrite",
            "help": "Allow overwrite output file if already exists.",
            "type": "outfile#overwrite"
        },
        {
            "name": "sounder_type",
            "type": "string",
            "key": "-sounder_type",
            "choices": [
                "AUTO",
                "EM1002_ALL",
                "EM2040_ALL",
                "EM120_ALL",
                "EM122_ALL",
                "EM302_ALL",
                "EM710_ALL",
                "ME70_ALL",
                "EM2040_KMALL",
                "EM124_KMALL",
                "EM304_KMALL",
                "EM712_KMALL",
                "7150_S7K",
                "7125_S7K",
                "7111_S7K"
            ],
            "help": "Sounder type for all datafiles",
            "default": "AUTO"
        },
        {
            "name": "i_dtm",
            "key": "-i_dtm",
            "long_key": "--i_dtm",
            "help": "Input reference DTM file (leave empty to ignore incidence angle corrections)",
            "nargs": "?",
            "type": "file(content_type=DTM_NETCDF_4)"
        },
        {
            "name": "i_meanmodel",
            "key": "-i_meanmodel",
            "long_key": "--i_meanmodel",
            "help": "Input BSAR file\n(optional absolute BS measurements by incidence angle used for calibration)",
            "nargs": "?",
            "type": "file(content_type=BSAR_NETCDF_4)"
        },
        {
            "name": "mask",
            "key": "-m",
            "long_key": "--mask",
            "help": "Mask file list (*.kml or *.shp)",
            "nargs": "+",
            "type": "file(content_type=KML_XML|SHAPEFILE)"
        },
        {
            "name": "use_snippets",
            "key": "-snippets",
            "long_key": "--use_snippets",
            "help": "Use snippets to recompute mean backscatter value per detection",
            "type": "bool",
            "default": false
        },
        {
            "name": "use_svp",
            "key": "-svp",
            "long_key": "--use_svp",
            "help": "Use embedded sound velocity profiles for incidence angles correction",
            "type": "bool",
            "default": true
        },
        {
            "name": "use_insonified_area",
            "key": "-ia",
            "long_key": "--use_insonified_area",
            "help": "Recompute insonified area from seafloor incidence angles",
            "type": "bool",
            "default": true
        },
        {
            "name": "remove_compensation",
            "key": "-comp",
            "long_key": "--remove_compensation",
            "help": "Remove angular compensation (default true)",
            "type": "bool",
            "default": true
        },
        {
            "name": "remove_calibration",
            "key": "-calib",
            "long_key": "--remove_calibration",
            "help": "Remove calibration (BScorr from kmall files) (default true)",
            "type": "bool",
            "default": true
        },
        {
            "name": "integration_method",
            "key": "-integration_method",
            "help": "Method to use to integrate BS values",
            "type": "string",
            "choices": [
                "MEAN",
                "MEDIAN"
            ],
            "default": "MEAN"
        },
        {
            "name": "linear_scale",
            "key": "-linear_scale",
            "help": "Scale to use for BS values integration (energy or amplitude)",
            "type": "string",
            "choices": [
                "AMPLITUDE",
                "ENERGY"
            ],
            "default": "ENERGY"
        }
    ]
}