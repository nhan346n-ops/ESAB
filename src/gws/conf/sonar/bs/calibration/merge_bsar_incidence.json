{
    "name": "Merge/Fit BSAR incidence curves",
    "function": "pyat.sonarscope.bs_correction.mean_bs_processes.merge_bsar_incidence_process",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/sonar/bs/calibration/merge_bsar_incidence.html",
    "parameters": [
        {
            "name": "i_path",
            "key": "-in",
            "long_key": "--i_path",
            "help": "Input file (.bsar.nc)",
            "nargs": "1",
            "type": "infile(content_type=BSAR_NETCDF_4)"
        },
        {
            "name": "o_path",
            "key": "-o",
            "long_key": "--o_path",
            "help": "Backscatter angular response file",
            "type": "outfile(content_type=BSAR_NETCDF_4,suffix=common)"
        },
        {
            "name": "overwrite",
            "key": "-ow",
            "long_key": "--overwrite",
            "help": "Allow overwrite output file if already exists.",
            "type": "outfile#overwrite"
        },
        {
            "name": "use_raw_data",
            "key": "-rd",
            "long_key": "--raw_data",
            "help": "Use raw mean backscatter values and counts as weights;\notherwise, use smoothed mean values",
            "type": "bool",
            "default": true
        },
        {
            "name": "apply_gsab_fitting",
            "key": "-gsab",
            "long_key": "--apply_gsab_fitting",
            "help": "Apply auto GSAB fitting with 6 parameters to the mean BSAR incidence curve",
            "type": "bool",
            "default": false
        }
    ]
}
