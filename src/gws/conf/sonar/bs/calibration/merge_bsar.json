{
    "name": "Merge BSAR models",
    "function": "pyat.sonarscope.bs_correction.mean_bs_processes.merge_bsar_process",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/sonar/bs/calibration/merge_bsar.html",
    "parameters": [
        {
            "name": "i_paths",
            "key": "-in",
            "long_key": "--i_paths",
            "help": "Input files (.bsar.nc)",
            "nargs": "*",
            "type": "infile(content_type=BSAR_NETCDF_4)"
        },
        {
            "name": "o_path",
            "key": "-o",
            "long_key": "--o_path",
            "help": "Backscatter angular response file",
            "type": "outfile(content_type=BSAR_NETCDF_4,suffix=merged)"
        },
        {
            "name": "overwrite",
            "key": "-ow",
            "long_key": "--overwrite",
            "help": "Allow overwrite output file if already exists.",
            "type": "outfile#overwrite"
        }
    ]
}
