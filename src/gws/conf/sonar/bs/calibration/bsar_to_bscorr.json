{
    "name": "Export BSAR to bscorr",
    "function": "pyat.sonarscope.bs_correction.bscorr_exporter.bsar_to_bscorr_process",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/sonar/bs/calibration/bsar_to_bscorr.html",
    "parameters": [
        {
            "name": "i_path",
            "key": "-in",
            "help": "Input file (.bsar.nc)",
            "nargs": "1",
            "type": "infile(content_type=BSAR_NETCDF_4)"
        },
        {
            "name": "i_bscorr_path",
            "key": "-i_bscorr_path",
            "help": "Input bscorr file to be updated (.txt)",
            "type": "file(content_type=UNDEFINED,extension=txt)"
        },
        {
            "name": "o_path",
            "key": "-o",
            "help": "Output bscorr file (.txt)",
            "type": "outfile(content_type=UNDEFINED,suffix=bscorr,extension=txt)"
        },
        {
            "name": "overwrite",
            "key": "-ow",
            "long_key": "--overwrite",
            "help": "Allow overwrite output file if already exists.",
            "type": "outfile#overwrite"
        }
    ]
}
