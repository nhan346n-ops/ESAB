{
    "name": "Extract bscorr from XSF",
    "function": "pyat.sonarscope.bs_correction.bscorr_exporter.xsf_to_bscorr_process",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/sonar/bs/calibration/xsf_to_bscorr.html",
    "parameters": [
        {
            "name": "i_path",
            "key": "-in",
            "help": "Input file (.xsf.nc)",
            "nargs": "1",
            "type": "infile(content_type=XSF_NETCDF_4)"
        },
        {
            "name": "o_path",
            "key": "-o",
            "help": "bscorr file (.txt)",
            "type": "outfile(content_type=UNDEFINED,suffix=bscorr,extension=txt)"
        },
        {
            "name": "overwrite",
            "key": "-ow",
            "long_key": "--overwrite",
            "help": "Allow overwrite output file if already exists.",
            "type": "outfile#overwrite"
        }
    ]
}
