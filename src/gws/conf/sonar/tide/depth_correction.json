{
    "name": "Tide/draught correction",
    "function": "pyat.xsf.xsf_depth_correction.process",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/sonar/tide/depth_correction.html",
    "parameters": [
        {
            "name": "i_paths",
            "help": "Input file list (.xsf.nc)",
            "nargs": "+",
            "type": "infile(content_type=XSF_NETCDF_4)"
        },
        {
            "name": "o_paths",
            "help": "Output file (.xsf.nc)",
            "nargs": "+",
            "type": "outfile(extension=xsf.nc,suffix=tide)"
        },
        {
            "name": "overwrite",
            "key": "--overwrite",
            "help": "Allow to overwrite file if already exists.",
            "type": "outfile#overwrite"
        },
        {
            "name": "tide_correction",
            "type": "depth_correction#tide_correction",
            "help": "Configure depth corrections"
        },
        {
            "name": "tide_type",
            "type": "depth_correction#tide_type"
        },
        {
            "name": "tide_source",
            "type": "depth_correction#tide_source"
        },
        {
            "name": "tide_file",
            "type": "depth_correction#tide_file"
        },
        {
            "name": "draught_correction",
            "type": "depth_correction#draught_correction"
        },
        {
            "name": "draught_file",
            "type": "depth_correction#draught_file"
        },
        {
            "name": "cut_file",
            "key": "-cut_file",
            "help": "Select the cut file with time intervals",
            "type": "time_interval#cut_file"
        },
        {
            "name": "geo_mask_file",
            "key": "-geo_mask_file",
            "help": "Select a geographic mask (.shp)",
            "type": "time_interval#geo_mask_file"
        },
        {
            "name": "reverse_geo_mask",
            "key": "-reverse_geo_mask",
            "help": "Reverse geographic mask (keep data outside areas)",
            "type": "time_interval#reverse_geo_mask"
        },
        {
            "name": "start_date",
            "key": "-start_date",
            "type": "time_interval#start_date"
        },
        {
            "name": "end_date",
            "key": "-end_date",
            "type": "time_interval#end_date"
        }
    ]
}
