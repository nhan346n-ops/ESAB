{
    "name": "Automatic navigation shift",
    "function": "pyat.xsf.navshift.isobath_registration.apply_on_sounder_files",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/sonar/nav/isobath_registration.html",
    "parameters": [
        {
            "name": "i_paths",
            "key": "-i",
            "long_key": "--i_paths",
            "help": "Input file list (.mbg, .xsf.nc)",
            "nargs": "+",
            "type": "infile(content_type=MBG_NETCDF_3|XSF_NETCDF_4)"
        },
        {
            "name": "i_dtm",
            "key": "-i_dtm",
            "long_key": "--i_dtm",
            "help": "Input reference DTM file",
            "nargs": "1",
            "type": "file(content_type=DTM_NETCDF_4)"
        },
        {
            "name": "o_path",
            "key": "-o_path",
            "help": "Output navigation file (.nvi.nc)",
            "nargs": "1",
            "type": "outfile(content_type=NVI_V2_NETCDF_4)"
        },
        {
            "name": "overwrite",
            "key": "-ow",
            "long_key": "--overwrite",
            "help": "Allow overwrite output file if already exists",
            "type": "outfile#overwrite"
        },
        {
            "name": "cell_size",
            "key": "-cs",
            "long_key": "--cell_size",
            "help": "DTM cell size (m)",
            "type": "float",
            "default": 4
        },
        {
            "name": "isobath_interval",
            "type": "float",
            "key": "-i",
            "long_key": "--isobath_interval",
            "help": "Isobath interval (m)",
            "default": 50
        },
        {
            "name": "max_dist",
            "key": "-md",
            "long_key": "--max_dist",
            "help": "Maximum allowed shift amplitude (m)",
            "type": "float",
            "default": 100
        },
        {
            "name": "vertex_distance",
            "key": "-vd",
            "long_key": "--vertex_distance",
            "help": "Isobath resampling distance (m)",
            "type": "float",
            "default": 4
        },
        {
            "name": "min_overlap",
            "key": "-mo",
            "long_key": "--min_overlap",
            "help": "Minimum matching isobath vertices",
            "type": "int",
            "default": 6
        }
    ]
}
