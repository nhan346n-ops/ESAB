{
    "name": "Generate Cut file from XSF files",
    "function": "pyat.xsf.xsf_to_cut.XsfToCut",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/sonar/nav/generate_cut_file_from_xsf.html",
    "parameters": [
        {
            "name": "i_paths",
            "key": "-i",
            "long_key": "--i_paths",
            "help": "Input file list (.xsf.nc)",
            "nargs": "+",
            "type": "infile(content_type=XSF_NETCDF_4)"
        },
        {
            "name": "o_path",
            "key": "-o_path",
            "help": "cut file (.cut)",
            "nargs": "1",
            "type": "outfile(extension=cut)"
        },
        {
            "name": "overwrite",
            "key": "-ow",
            "long_key": "--overwrite",
            "help": "Allow overwrite output file if already exists.",
            "type": "outfile#overwrite"
        }
    ]
}
