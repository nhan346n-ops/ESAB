{
    "name": "Longitudinal Slicer (g3d)",
    "function": "pyat.wc.longitudinal_section.LongitudinalSection",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/sonar/wc/longitudinal_section.html",
    "pages": [
        {
            "title": "Grids parameters",
            "description": "Complete arguments to configure slices",
            "parameters": [
                "delta_across",
                "grid_count",
                "delta_elevation",
                "delta_along",
                "interpolate"
            ]
        }
    ],
    "parameters": [
        {
            "name": "i_paths",
            "key": "-in",
            "long_key": "--i_paths",
            "help": "Input file list (.xsf.nc)",
            "nargs": "+",
            "type": "infile(content_type=XSF_NETCDF_4)"
        },
        {
            "name": "o_paths",
            "key": "-out",
            "long_key": "--o_paths",
            "help": "Output file list (.g3d.nc)",
            "nargs": "*|1",
            "type": "outfile(suffix=WCLongitudinalEcho,extension=g3d.nc)"
        },
        {
            "name": "delta_across",
            "key": "-dac",
            "long_key": "--delta_across",
            "help": "Across spacing (m) : distance between slices / slice thickness (0 = auto)",
            "nargs": "1",
            "type": "float",
            "function": "functions/evaluate_longitudinal_section_arguments.json"
        },
        {
            "name": "grid_count",
            "key": "-g",
            "long_key": "--grid_count",
            "help": "    and/or Grid count : number of slice (0 = auto)",
            "nargs": "1",
            "type": "int"
        },
        {
            "name": "delta_elevation",
            "key": "-del",
            "long_key": "--delta_elevation",
            "help": "Vertical sample size (m)",
            "nargs": "1",
            "type": "float",
            "function": "functions/evaluate_longitudinal_section_arguments.json"
        },
        {
            "name": "delta_along",
            "key": "-dal",
            "long_key": "--delta_along",
            "help": "Alongtrack sample size (m)",
            "nargs": "1",
            "type": "float",
            "function": "functions/evaluate_longitudinal_section_arguments.json"
        },
        {
            "name": "interpolate",
            "key": "-interpolate",
            "long_key": "--interpolate",
            "help": "Use linear interpolation to fill gaps (may highly increase time processing)",
            "nargs": "1",
            "type": "bool"
        },
        {
            "name": "filters",
            "key": "-filters",
            "long_key": "--filters",
            "help": "Optional WC filters configuration",
            "type": "wc_filters"
        },
        {
            "name": "layers",
            "key": "-l",
            "long_key": "--layers",
            "help": "Select layers to export",
            "type": "checklist",
            "choices": [
                "backscatter_mean",
                "backscatter_max",
                "backscatter_comp_mean",
                "backscatter_comp_max"
            ],
            "default": [
                "backscatter_mean"
            ]
        },
        {
            "name": "normalization_offset",
            "key": "-no",
            "long_key": "--normalization_offset",
            "help": "Range normalization offset (dB) : ref level for compensated layer",
            "nargs": "1",
            "type": "float",
            "default": "0"
        },
        {
            "name": "overwrite",
            "key": "-o",
            "long_key": "--overwrite",
            "help": "Allow to overwrite file if already exists.",
            "type": "outfile#overwrite"
        }
    ]
}
