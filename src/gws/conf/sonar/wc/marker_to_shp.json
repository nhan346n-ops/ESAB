{
    "name": "Marker (.csv) to Shapefile (.shp)",
    "function": "pyat.csv.marker_to_shape_exporter.MarkersToShapefileExporter",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/sonar/wc/marker_to_shp.html",
    "pages": [
        {
            "title": "Shapefile options",
            "description": "Metadata of Shapefile",
            "parameters": [
                "author",
                "cruise",
                "tool"
            ]
        }
    ],
    "parameters": [
        {
            "name": "i_paths",
            "key": "-i",
            "long_key": "--i_paths",
            "help": "Input file list (.csv)",
            "nargs": "+",
            "type": "infile(content_type=MARKER_CSV)"
        },
        {
            "name": "o_paths",
            "key": "-o",
            "long_key": "--o_paths",
            "help": "Output file list (.shp)",
            "nargs": "+",
            "type": "outfile(content_type=SHAPEFILE)"
        },
        {
            "name": "overwrite",
            "key": "-ow",
            "long_key": "--overwrite",
            "help": "Allow to overwrite file if already exists.",
            "type": "outfile#overwrite"
        },
        {
            "name": "author",
            "type": "string",
            "key": "-a",
            "long_key": "--author",
            "help": "Author",
            "default": ""
        },
        {
            "name": "cruise",
            "type": "string",
            "key": "-a",
            "long_key": "--cruise",
            "help": "Cruise",
            "default": ""
        },
        {
            "name": "tool",
            "type": "string",
            "key": "-a",
            "long_key": "--tool",
            "help": "Tool",
            "default": ""
        }
    ]
}
