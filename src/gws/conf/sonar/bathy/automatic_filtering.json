{
    "name": "Automatic Filtering",
    "function": "pyat.xsf.bathy.automatic_filtering.process",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/sonar/bathy/automatic_filtering.html",
    "parameters": [
        {
            "name": "i_paths",
            "help": "Input file list (.xsf.nc)",
            "nargs": "+",
            "type": "infile(content_type=XSF_NETCDF_4)"
        },
        {
            "name": "o_paths",
            "help": "Output file (xsf.nc)",
            "nargs": "+",
            "type": "outfile(extension=xsf.nc,suffix=autofilter)"
        },
        {
            "name": "overwrite",
            "key": "--overwrite",
            "help": "Allow to overwrite file if already exists.",
            "type": "outfile#overwrite"
        },
        {
            "name": "projection",
            "type": "projection(restore=false)",
            "help": "The projection used to transform sound coordinates"
        },
        {
          "name": "contamination",
          "help": "The proportion of outliers in the data set. Range is ]0, 0.5].",
          "type": "float",
          "default": 0.05
        }
    ]
}
