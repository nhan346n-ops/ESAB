{
    "name": "Cut / Merge NVI files",
    "help": "https://fleet.gitlab-pages.ifremer.fr/data-processing/globe/globe-documentation/pyat/navigation/merge_nvi.html",
    "function": "pyat.xsf.netcdf_merger_bridge.NcMergerBridge",
    "parameters": [
        {
            "name": "i_paths",
            "key": "-i",
            "long_key": "--i_paths",
            "help": "Input file list (.nvi.nc)",
            "nargs": "+",
            "type": "infile(content_type=NVI_V2_NETCDF_4)"
        },
        {
            "name": "cut_file",
            "key": "-cut_file",
            "help": "Select the cut file with time intervals",
            "type": "time_interval#cut_file"
        },
        {
            "name": "geo_mask_file",
            "key": "-geo_mask_file",
            "help": "Select a geographic mask (.shp)",
            "type": "time_interval#geo_mask_file"
        },
        {
            "name": "reverse_geo_mask",
            "key": "-reverse_geo_mask",
            "help": "Reverse geographic mask (keep data outside areas)",
            "type": "time_interval#reverse_geo_mask"
        },
        {
            "name": "start_date",
            "key": "-start_date",
            "type": "time_interval#start_date"
        },
        {
            "name": "end_date",
            "key": "-end_date",
            "type": "time_interval#end_date"
        },
        {
            "name": "o_paths",
            "key": "-o_paths",
            "help": "Output file (nvi.nc)",
            "nargs": "+",
            "type": "outfile(extension=nvi.nc)"
        },
        {
            "name": "overwrite",
            "key": "--overwrite",
            "help": "Allow to overwrite file if already exists.",
            "type": "outfile#overwrite"
        }
    ]
}
